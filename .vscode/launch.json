{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run API (Uvicorn)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app.main:app", "--reload"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Run Daily Watchlist Scan",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/daily_scan.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },
    {
      "name": "Run Backtest (VOO 10y)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/cli.py",
      "args": ["backtest", "--ticker", "VOO", "--period", "10y"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    }
  ]
}
